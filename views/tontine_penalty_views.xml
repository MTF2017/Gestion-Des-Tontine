<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- ============================= -->
    <!-- VUE LISTE DES PÉNALITÉS -->
    <!-- ============================= -->

    <record id="view_tontine_penalty_list" model="ir.ui.view">
        <field name="name">tontine.penalty.list</field>
        <field name="model">tontine.penalty</field>
        <field name="arch" type="xml">
            <list string="Pénalités">
                <field name="subscription_id"/>
                <field name="period"/>
                <field name="reason"/>
                <field name="amount"/>
                <field name="payment_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================= -->
    <!-- VUE FORMULAIRE -->
    <!-- ============================= -->

    <record id="view_tontine_penalty_form" model="ir.ui.view">
        <field name="name">tontine.penalty.form</field>
        <field name="model">tontine.penalty</field>
        <field name="arch" type="xml">
            <form string="Pénalité">
                <sheet>
                    <group>
                        <group>
                            <field name="subscription_id" domain="[('group_id.state', '=', 'active')]"/>
                            <field name="period"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="reason"/>
                            <field name="payment_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================= -->
    <!-- ACTION -->
    <!-- ============================= -->

    <record id="action_tontine_penalty" model="ir.actions.act_window">
        <field name="name">Pénalités</field>
        <field name="res_model">tontine.penalty</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>