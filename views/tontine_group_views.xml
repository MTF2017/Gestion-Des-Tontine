<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- ============================= -->
    <!-- VUE LISTE DES TONTINES -->
    <!-- ============================= -->

    <record id="view_tontine_group_list" model="ir.ui.view">
        <field name="name">tontine.group.list</field>
        <field name="model">tontine.group</field>
        <field name="arch" type="xml">
            <list string="Tontines">
                <field name="name"/>
                <field name="manager_id"/>
                <field name="amount"/>
                <field name="frequency"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'active'"
                    decoration-muted="state == 'closed'"/>
            </list>
        </field>
    </record>


    <!-- ============================= -->
    <!-- VUE FORMULAIRE DES TONTINES -->
    <!-- ============================= -->

    <record id="view_tontine_group_form" model="ir.ui.view">

        <field name="name">tontine.group.form</field>
        <field name="model">tontine.group</field>

        <field name="arch" type="xml">

            <form string="Tontine">

                <header>

                    <button name="action_activate"
                            type="object"
                            string="Activer"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_reset_draft" type="object"
                        string="Remettre en brouillon"
                        groups="gestion_tontine.group_tontine_manager"
                        confirm="Cela va réinitialiser l'état de la tontine en brouillon. Continuer ?"
                        invisible="state == 'draft' or not is_manager"/>

                    <button name="action_close"
                            type="object"
                            string="Clôturer"
                            invisible="state != 'active'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,active,closed"/>

                </header>


                <sheet>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>


                    <group>

                        <group string="Informations générales">
                            <field name="manager_id"/>
                            <field name="is_manager"  invisible="1"/>
                            <field name="amount"/>
                            <field name="frequency"/>
                        </group>


                        <group string="Période">
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>

                    </group>


                    <notebook>

                        <page string="Participants">

                            <field name="member_ids" readonly="state != 'draft'">

                                <list editable="bottom">

                                    <field name="member_id"/>
                                    <field name="order"/>
                                    <field name="join_date"/>

                                </list>

                            </field>

                        </page>

                    </notebook>


                </sheet>

            </form>

        </field>

    </record>


    <!-- ============================= -->
    <!-- ACTION -->
    <!-- ============================= -->

    <record id="action_tontine_group" model="ir.actions.act_window">

        <field name="name">Tontines</field>

        <field name="res_model">tontine.group</field>

        <field name="view_mode">list,form</field>

    </record>


</odoo>